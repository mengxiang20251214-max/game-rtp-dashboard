      "Bash(/Users/macbookpro/.local/bin/pnpm -v)",
      "Bash(/Users/macbookpro/.local/bin/pnpm install *)",
      "Bash(/Users/macbookpro/.local/bin/pnpm exec *)",
      "Bash(./node_modules/.bin/prisma db *)",
      "Bash(./node_modules/.bin/tsx prisma/seed.ts)",
      "Bash(./node_modules/.bin/prisma generate *)",
      "Bash(./node_modules/.bin/tsc --noEmit)",
      "Bash(echo \"TSC_EXIT_$?\")",
      "Bash(./node_modules/.bin/next dev *)",
      "Bash(tee /tmp/rtp-dev.log)"
    ]
  }
