{
  "permissions": {
    "allow": [
      "Bash(echo \"node: $?\")",
      "Bash(pnpm -v)",
      "Bash(npm -v)",
      "Bash(ping -c1 -t2 registry.npmjs.org)",
      "Bash(corepack enable *)",
      "Bash(corepack prepare *)",
      "Bash(npm i *)",
      "Bash(export COREPACK_HOME=\"$HOME/.cache/corepack\")",
      "Bash(corepack pnpm@latest -v)",
      "Bash(mkdir -p /Users/macbookpro/.local/bin)",
      "Bash(cat)",
