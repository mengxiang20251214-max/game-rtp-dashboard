generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// category/status 以 String 存储（沿用 SQLite 时期的约定，PostgreSQL 同样兼容），
// 由应用层（src/types + game-utils）约束取值：
//   category: "SLOT" | "TABLE" | "LIVE"
//   status:   "NORMAL" | "WARNING" | "CRITICAL"
model Game {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String   @default("SLOT")
  image       String?
  rtp         Float    @default(0)
  targetRtp   Float    @default(96.5)
  status      String   @default("NORMAL")
  playerCount Int      @default(0)
  totalBets   Float    @default(0)
  totalWins   Float    @default(0)
  trend       String   @default("[]") // JSON 编码的 number[]，由 parseTrend 解析
  rank        Int      @default(0)
  isActive    Boolean  @default(true)
  description String?

  // SEO 字段（每个游戏可自定义）
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([rank])
}

// 页面级 SEO 配置（按 key 标识，如 "home"）
model SeoConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  title       String?
  description String?
  keywords    String?
  ogImage     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
