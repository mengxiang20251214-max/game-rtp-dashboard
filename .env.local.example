# ─────────────────────────────────────────────
#  环境变量示例 —— 复制为 .env.local 后填写
# ─────────────────────────────────────────────

# 数据库（开发：SQLite）
DATABASE_URL="file:./dev.db"

# NextAuth
# 生成密钥: openssl rand -base64 32
NEXTAUTH_SECRET="please-change-this-to-a-random-secret-string"
NEXTAUTH_URL="http://localhost:3000"

# 后台管理密码
ADMIN_PASSWORD="admin123"
